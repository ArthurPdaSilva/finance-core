# Backend example environment variables
# Copy to backend/.env and fill values before running the backend

# OpenAI API key used by the project's LLM integrations
OPENAI_API_KEY=

# SQLite URL for SQLAlchemy (example uses local file)
# For SQLite: sqlite:///app.db
DATABASE_URL=sqlite:///app.db
DATABASE_NAME=app.db

# Langfuse (optional) - used for tracing / telemetry
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Simple API key used by the frontend to call the backend endpoints
# Keep this secret in production
API_KEY=your_api_key_here
